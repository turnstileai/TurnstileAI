{
  "name": "@turnstileai/sdk",
  "version": "0.1.10",
  "description": "TypeScript SDK for verified AI inference, routing, and signed compute receipts.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "turnstileai": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test dist/test/**/*.test.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "sdk",
    "typescript",
    "openai",
    "inference",
    "verification",
    "receipt",
    "solana",
    "routing",
    "llm",
    "turnstileai"
  ],
  "author": "TurnstileAI",
  "license": "MIT",
  "homepage": "https://github.com/turnstileai/TurnstileAI",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/turnstileai/TurnstileAI.git"
  },
  "bugs": {
    "url": "https://github.com/turnstileai/TurnstileAI/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "openai": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.0.0"
  }
}