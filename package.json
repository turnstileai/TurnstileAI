{
  "name": "@turnstileai/sdk",
  "version": "0.1.17",
  "description": "Official TypeScript/JavaScript SDK for the TurnstileAI verifiable inference gateway.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": "./dist/cli.js",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "inference",
    "gateway",
    "receipts",
    "verifiable",
    "openai",
    "llm",
    "audit",
    "solana",
    "turnstileai"
  ],
  "author": "TurnstileAI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/turnstileai/TurnstileAI"
  },
  "homepage": "https://github.com/turnstileai/TurnstileAI",
  "bugs": {
    "url": "https://github.com/turnstileai/TurnstileAI/issues"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "openai": "^4.0.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
